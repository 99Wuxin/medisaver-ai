{
  "name": "healthcare-billing-arbitrage",
  "private": true,
  "workspaces": [
    "server",
    "client"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev -w server\" \"npm run dev -w client\"",
    "build": "npm run build -w client",
    "start": "npm run start -w server",
    "deploy:worker": "wrangler deploy --config server/wrangler.toml"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
